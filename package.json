{
  "name": "discord-osint-assistant",
  "version": "2.2.0",
  "description": "A powerful Discord bot for Open Source Intelligence (OSINT) gathering and analysis",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "deploy": "node deploy-commands.js",
    "deploy:global": "node deploy-commands.js --global",
    "deploy:force": "bun run clear && bun run deploy",
    "clear": "node clear-commands.js --force",
    "clear:global": "node clear-commands.js --global --force",
    "clear:all": "node clear-commands.js --all --force",
    "clear:list": "node clear-commands.js --list",
    "redeploy": "bun run clear && bun run deploy",
    "redeploy:global": "bun run clear:global && bun run deploy:global",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke-test.js",
    "lint": "eslint .",
    "clean": "rm -rf temp/* || rmdir /s /q temp 2>nul || true"
  },
  "keywords": [
    "discord",
    "bot",
    "osint",
    "intelligence",
    "reconnaissance",
    "investigation",
    "security",
    "analysis",
    "blockchain",
    "social-engineering",
    "cybersecurity"
  ],
  "author": "gl0bal01",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gl0bal01/discord-osint-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/gl0bal01/discord-osint-assistant/issues"
  },
  "homepage": "https://github.com/gl0bal01/discord-osint-assistant#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1044.0",
    "@discordjs/rest": "^2.6.1",
    "axios": "^1.16.0",
    "cheerio": "^1.2.0",
    "discord-api-types": "^0.38.47",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "murmurhash": "^2.0.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  },
  "overrides": {
    "undici": "^6.24.0",
    "fast-xml-parser": ">=5.7.0",
    "lodash": ">=4.17.24",
    "brace-expansion": ">=5.0.5",
    "picomatch": ">=4.0.4",
    "postcss": ">=8.5.10",
    "vite": ">=8.0.5"
  }
}
