# Discord (required)
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# Channel for /bob-monitor alerts
MONITOR_CHANNEL_ID=

# Access control (comma-separated, leave empty to allow all)
ALLOWED_GUILD_IDS=
OSINT_ALLOWED_ROLES=

# API keys (all optional — commands degrade gracefully without them)
DNSDUMPSTER_TOKEN=
WHOXY_API_KEY=
HOSTIO_API_KEY=
AVIATIONSTACK_API_KEY=
AIRPORTDB_API_KEY=
PAPPERS_API_KEY=
NIKE_TOKEN=
AI_API_KEY=
VIRUSTOTAL_API_KEY=

# Blockchain explorers
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# AWS Rekognition
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Security webhook for redirect-chain alerts
SECURITY_WEBHOOK_URL=

# External tool paths (only set if not in PATH)
# EXIFTOOL_PATH=exiftool
# SHERLOCK_PATH=sherlock
# MAIGRET_PATH=maigret
# NUCLEI_PATH=nuclei
# NUCLEI_TEMPLATE_PATH=/opt/nuclei-templates/http/osint/user-enumeration
# JWT_TOOL_PATH=/opt/tools/jwt_tool
