# Discord Configuration (Required)
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_application_client_id
GUILD_ID=your_development_server_id

# Notification Channel
MONITOR_CHANNEL_ID=your_monitor_channel_id

# API Keys (Recommended)
WHOXY_API_KEY=
DNSDUMPSTER_TOKEN=
HOSTIO_API_KEY=
AVIATIONSTACK_API_KEY=
AIRPORTDB_API_KEY=
AI_API_KEY=
PAPPERS_API_KEY=
VIRUSTOTAL_API_KEY=

# AWS (for Rekognition)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Blockchain API Keys
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# Tool Paths (defaults to binary name in PATH)
EXIFTOOL_PATH=exiftool
SHERLOCK_PATH=sherlock
MAIGRET_PATH=maigret
NUCLEI_PATH=nuclei
NUCLEI_TEMPLATE_PATH=/opt/nuclei-templates/http/osint/user-enumeration

# JWT Tool
JWT_TOOL_PATH=/opt/tools/jwt_tool
JWT_TEMP_FOLDER=/tmp/jwt_analysis
JWT_WORDLIST=/opt/rockyou.txt
JWT_TIMEOUT=120000

# Guild Whitelist (comma-separated guild IDs, leave empty to allow all)
ALLOWED_GUILD_IDS=

# Access Control
OSINT_ALLOWED_ROLES=

# Rate Limiting
RATE_LIMIT_DAILY=200

# Security
SECURITY_WEBHOOK_URL=
